# Railway-hosted VunaBooks FastAPI base URL, including the /api prefix.
# Example: https://api.vunabooks.com/api
VITE_VUNABOOKS_API_BASE_URL="http://localhost:8000/api"

# Public app origin for planner auth redirects and deep links.
# Example: https://planner.vunabooks.com
VITE_PLANNER_APP_URL="http://localhost:3000"

# Optional environment label for UI/debugging.
# Example: vercel-simple, railway-preview, local
VITE_PLANNER_DEPLOYMENT_TARGET="local"
